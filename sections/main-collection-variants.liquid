{% comment %}
  Main Collection Variants section

  Loops through every product in the collection and expands each variant into its own card.
  Blocks control what is rendered inside each card (Image, Title, Variant option,
  Scent description, Price) and can be reordered or removed in the theme editor.
{% endcomment %}

{% liquid
  # Resolve card min-width using the same logic as util-product-grid-card-size
  if section.settings.layout_type == 'organic'
    if section.settings.product_grid_width == 'centered'
      assign card_min_width = '250px'
    else
      assign card_min_width = '260px'
    endif
  elsif section.settings.product_grid_width == 'centered'
    case section.settings.product_card_size
      when 'small'
        assign card_min_width = '165px'
      when 'large'
        assign card_min_width = '340px'
      when 'extra-large'
        assign card_min_width = '480px'
      else
        assign card_min_width = '250px'
    endcase
  else
    case section.settings.product_card_size
      when 'small'
        assign card_min_width = '180px'
      when 'large'
        assign card_min_width = '365px'
      when 'extra-large'
        assign card_min_width = '530px'
      else
        assign card_min_width = '260px'
    endcase
  endif
%}

{% style %}
  .variant-grid--{{ section.id }} {
    display: grid;
    list-style: none;
    margin: 0;
    padding: 0;
    {% if section.settings.mobile_product_card_size == 'large' %}
      grid-template-columns: repeat(1, 1fr);
    {% else %}
      grid-template-columns: repeat(2, 1fr);
    {% endif %}
    gap: {{ section.settings.columns_gap_vertical | at_most: 12 }}px {{ section.settings.columns_gap_horizontal | at_most: 12 }}px;
  }

  @media screen and (min-width: 750px) {
    .variant-grid--{{ section.id }} {
      grid-template-columns: repeat(auto-fill, minmax({{ card_min_width }}, 1fr));
      gap: {{ section.settings.columns_gap_vertical }}px {{ section.settings.columns_gap_horizontal }}px;
    }
  }

  .variant-section-inner--{{ section.id }} {
    {% if section.settings.product_grid_width == 'full-width' %}
      grid-column: 1 / -1;
      padding-inline-start: 0;
      padding-inline-end: 0;
    {% elsif section.settings.full_width_on_mobile %}
      grid-column: 1 / -1;
      padding-inline-start: 0;
      padding-inline-end: 0;
    {% else %}
      padding-inline-start: 0;
      padding-inline-end: 0;
    {% endif %}
  }

  @media screen and (min-width: 750px) {
    .variant-section-inner--{{ section.id }} {
      {% if section.settings.product_grid_width == 'full-width' %}
        grid-column: 1 / -1;
        padding-inline-start: {{ section.settings['padding-inline-start'] }}px;
        padding-inline-end: {{ section.settings['padding-inline-end'] }}px;
      {% else %}
        grid-column: 2;
        padding-inline-start: {{ section.settings['padding-inline-start'] }}px;
        padding-inline-end: {{ section.settings['padding-inline-end'] }}px;
      {% endif %}
    }
  }

  .variant-card-item--{{ section.id }} {
    border-radius: {{ section.settings.card_border_radius }}px;
    overflow: hidden;
    {% if section.settings.card_border == 'solid' %}
      border: {{ section.settings.card_border_width }}px solid rgb(var(--color-foreground-rgb) / {{ section.settings.card_border_opacity | times: 0.01 }});
    {% endif %}
    padding-block-start: {{ section.settings.card_padding_top }}px;
    padding-block-end: {{ section.settings.card_padding_bottom }}px;
    padding-inline-start: {{ section.settings.card_padding_left }}px;
    padding-inline-end: {{ section.settings.card_padding_right }}px;
  }
{% endstyle %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="section color-{{ section.settings.color_scheme }}"
  style="
    padding-block-start: {{ section.settings['padding-block-start'] }}px;
    padding-block-end: {{ section.settings['padding-block-end'] }}px;
  "
>
  <div class="variant-section-inner--{{ section.id }}">
    {% paginate collection.products by 24 %}
      {% if collection.products_count == 0 %}
        <div class="main-collection-grid__empty">
          <h2 class="main-collection-grid__empty-title h2">
            {{ 'content.no_products_found' | t }}
          </h2>
          <p>
            {{ 'content.use_fewer_filters_html' | t: link: collection.url, class: 'main-collection-grid__empty-link' }}
          </p>
        </div>
      {% else %}
        <ul class="variant-grid--{{ section.id }}" role="list">
          {% for product in collection.products %}
            {% for variant in product.variants %}
              {% assign variant_image = variant.featured_image | default: product.featured_media.preview_image %}
              {% assign scent_desc = variant.metafields.custom.scent_card_description %}
              {% liquid
                assign has_quick_add = false
                if settings.quick_add and variant.available
                  assign has_quick_add = true
                endif
                assign has_mobile_quick_add = false
                if has_quick_add and settings.mobile_quick_add
                  assign has_mobile_quick_add = true
                endif
              %}

              <li
                class="
                  variant-card-item--{{ section.id }}
                  {% if section.settings.card_inherit_color_scheme == false %} color-{{ section.settings.card_color_scheme }}{% endif %}
                "
              >
                <product-card
                  class="variant-card"
                  data-product-id="{{ product.id }}"
                  style="
                    gap: {{ section.settings.card_gap }}px;
                    --quick-add-display: {% if has_quick_add %}flex{% else %}none{% endif %};
                    --quick-add-mobile-display: {% if has_mobile_quick_add %}flex{% else %}none{% endif %};
                    --quick-add-mobile-opacity: {% if has_mobile_quick_add %}1{% else %}0{% endif %};
                  "
                >
                  <a
                    href="{{ variant.url }}"
                    class="variant-card__link"
                    ref="productCardLink"
                    aria-label="{{ product.title }}{% unless variant.title == 'Default Title' %} - {{ variant.title }}{% endunless %}"
                  ></a>

                  {% for block in section.blocks %}
                    {% case block.type %}

                      {% when 'variant-gallery' %}
                        {% liquid
                          case block.settings.image_ratio
                            when 'portrait'
                              assign img_ratio = '4 / 5'
                            when 'square'
                              assign img_ratio = '1 / 1'
                            when 'landscape'
                              assign img_ratio = '16 / 9'
                            else
                              assign img_ratio = variant_image.aspect_ratio | default: '0.8'
                          endcase
                        %}
                        <div
                          class="variant-card__media"
                          style="
                            aspect-ratio: {{ img_ratio }};
                            border-radius: {{ block.settings.border_radius }}px;
                            {% if block.settings.border == 'solid' %}border: {{ block.settings.border_width }}px solid rgb(var(--color-foreground-rgb) / {{ block.settings.border_opacity | times: 0.01 }});{% endif %}
                            padding-block-start: {{ block.settings['padding-block-start'] }}px;
                            padding-block-end: {{ block.settings['padding-block-end'] }}px;
                            padding-inline-start: {{ block.settings['padding-inline-start'] }}px;
                            padding-inline-end: {{ block.settings['padding-inline-end'] }}px;
                          "
                          {{ block.shopify_attributes }}
                        >
                          {% if variant_image %}
                            {{
                              variant_image
                              | image_url: width: 800
                              | image_tag:
                                loading: 'lazy',
                                alt: variant_image.alt | default: product.title,
                                sizes: '(min-width: 750px) 25vw, 50vw',
                                widths: '275, 400, 550, 800'
                            }}
                          {% else %}
                            {{ 'product-1' | placeholder_svg_tag: 'variant-card__placeholder' }}
                          {% endif %}
                          {% if settings.quick_add or settings.mobile_quick_add %}
                            {% render 'quick-add', product: product, section_id: section.id, forced_variant: variant %}
                          {% endif %}
                        </div>

                      {% when 'variant-title' %}
                        <p
                          class="variant-card__title {{ block.settings.type_preset | default: 'paragraph' }}"
                          style="
                            text-align: {{ block.settings.alignment }};
                            padding-block-start: {{ block.settings['padding-block-start'] }}px;
                            padding-block-end: {{ block.settings['padding-block-end'] }}px;
                            padding-inline-start: {{ block.settings['padding-inline-start'] }}px;
                            padding-inline-end: {{ block.settings['padding-inline-end'] }}px;
                            {% render 'typography-style', settings: block.settings %}
                          "
                          {{ block.shopify_attributes }}
                        >{{ product.title }}</p>

                      {% when 'variant-option' %}
                        {% for option in product.options %}
                          {% unless product.options.size == 1 and variant.options[forloop.index0] == 'Default Title' %}
                            <p
                              class="variant-card__subtitle {{ block.settings.type_preset | default: '' }}"
                              style="
                                text-align: {{ block.settings.alignment | default: 'left' }};
                                padding-block-start: {{ block.settings['padding-block-start'] }}px;
                                padding-block-end: {{ block.settings['padding-block-end'] }}px;
                                padding-inline-start: {{ block.settings['padding-inline-start'] }}px;
                                padding-inline-end: {{ block.settings['padding-inline-end'] }}px;
                                {% render 'typography-style', settings: block.settings %}
                              "
                              {{ block.shopify_attributes }}
                            >{{ variant.options[forloop.index0] }}</p>
                          {% endunless %}
                        {% endfor %}

                      {% when 'variant-description' %}
                        {% if scent_desc != blank %}
                          <p
                            class="variant-card__description {{ block.settings.type_preset | default: '' }}"
                            style="
                              text-align: {{ block.settings.alignment | default: 'left' }};
                              padding-block-start: {{ block.settings['padding-block-start'] }}px;
                              padding-block-end: {{ block.settings['padding-block-end'] }}px;
                              padding-inline-start: {{ block.settings['padding-inline-start'] }}px;
                              padding-inline-end: {{ block.settings['padding-inline-end'] }}px;
                              {% render 'typography-style', settings: block.settings %}
                            "
                            {{ block.shopify_attributes }}
                          >{{ scent_desc.value | default: scent_desc }}</p>
                        {% endif %}

                      {% when 'variant-price' %}
                        <p
                          class="variant-card__price {{ block.settings.type_preset | default: '' }}"
                          style="
                            text-align: {{ block.settings.alignment | default: 'left' }};
                            padding-block-start: {{ block.settings['padding-block-start'] }}px;
                            padding-block-end: {{ block.settings['padding-block-end'] }}px;
                            padding-inline-start: {{ block.settings['padding-inline-start'] }}px;
                            padding-inline-end: {{ block.settings['padding-inline-end'] }}px;
                            {% render 'typography-style', settings: block.settings %}
                          "
                          {{ block.shopify_attributes }}
                        >
                          {% if block.settings.show_sale_price_first and variant.compare_at_price > variant.price %}
                            <span class="variant-card__price-sale">{{ variant.price | money }}</span>
                            <span class="variant-card__price-compare">{{ variant.compare_at_price | money }}</span>
                          {% else %}
                            {{ variant.price | money }}
                          {% endif %}
                        </p>

                    {% endcase %}
                  {% endfor %}

                </product-card>
              </li>
            {% endfor %}
          {% endfor %}
        </ul>

        {% render 'pagination-controls', paginate: paginate %}
      {% endif %}
    {% endpaginate %}
  </div>
</div>

{% style %}
  /* Fix missing CSS variables that quick-add.liquid depends on for positioning */
  .variant-card .quick-add {
    --padding-inline-end: 0px;
    --padding-block-end: 0px;
    --border-radius: 0px;
  }

  @media screen and (min-width: 750px) {
    product-card.variant-card .quick-add__button {
      display: flex !important;
      opacity: 0;
      transition: opacity 0.2s ease;
    }

    product-card.variant-card:hover .quick-add__button,
    product-card.variant-card:focus-within .quick-add__button {
      opacity: 1 !important;
    }
  }
{% endstyle %}

{% stylesheet %}
  .variant-card {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .variant-card__link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .variant-card__media {
    overflow: hidden;
    position: relative;
  }

  .variant-card__media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .variant-card__placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: rgb(var(--color-foreground-rgb) / var(--opacity-5));
  }

  .variant-card__title {
    font-family: var(--font-family, var(--font-body--family));
    font-size: var(--font-size, 1rem);
    font-weight: var(--font-weight, normal);
    color: var(--color, var(--color-foreground));
    text-transform: var(--text-transform, none);
    letter-spacing: var(--letter-spacing, normal);
    line-height: var(--line-height, normal);
    margin: 0;
  }

  .variant-card__subtitle {
    font-family: var(--font-family, var(--font-body--family));
    font-size: var(--font-size, 0.875rem);
    font-weight: var(--font-weight, normal);
    color: var(--color, var(--color-foreground));
    text-transform: var(--text-transform, none);
    letter-spacing: var(--letter-spacing, normal);
    line-height: var(--line-height, normal);
    opacity: 0.7;
    margin: 0;
  }

  .variant-card__description {
    font-family: var(--font-family, var(--font-body--family));
    font-size: var(--font-size, 0.875rem);
    font-weight: var(--font-weight, normal);
    color: var(--color, var(--color-foreground));
    text-transform: var(--text-transform, none);
    letter-spacing: var(--letter-spacing, normal);
    line-height: var(--line-height, normal);
    opacity: 0.7;
    margin: 0;
    white-space: pre-line;
  }

  .variant-card__price {
    font-family: var(--font-family, var(--font-body--family));
    font-size: var(--font-size, 1rem);
    font-weight: var(--font-weight, normal);
    color: var(--color, var(--color-foreground));
    text-transform: var(--text-transform, none);
    letter-spacing: var(--letter-spacing, normal);
    line-height: var(--line-height, normal);
    margin: 0;
  }

  .variant-card__price-compare {
    text-decoration: line-through;
    opacity: 0.6;
    margin-inline-start: 4px;
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Variant Collection",
  "enabled_on": {
    "templates": ["collection"]
  },
  "blocks": [
    {
      "type": "variant-gallery",
      "name": "t:names.product_image",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "t:content.resource_reference_product_media"
        },
        {
          "type": "select",
          "id": "image_ratio",
          "label": "t:settings.aspect_ratio",
          "options": [
            { "value": "adapt", "label": "t:options.auto" },
            { "value": "portrait", "label": "t:options.portrait" },
            { "value": "square", "label": "t:options.square" },
            { "value": "landscape", "label": "t:options.landscape" }
          ],
          "default": "adapt"
        },
        {
          "type": "header",
          "content": "t:content.borders"
        },
        {
          "type": "select",
          "id": "border",
          "label": "t:settings.style",
          "options": [
            { "value": "none", "label": "t:options.none" },
            { "value": "solid", "label": "t:options.solid" }
          ],
          "default": "none"
        },
        {
          "type": "range",
          "id": "border_width",
          "min": 0, "max": 100, "step": 1, "unit": "px",
          "label": "t:settings.thickness",
          "default": 1,
          "visible_if": "{{ block.settings.border != 'none' }}"
        },
        {
          "type": "range",
          "id": "border_opacity",
          "min": 0, "max": 100, "step": 1, "unit": "%",
          "label": "t:settings.opacity",
          "default": 100,
          "visible_if": "{{ block.settings.border != 'none' }}"
        },
        {
          "type": "range",
          "id": "border_radius",
          "label": "t:settings.border_radius",
          "min": 0, "max": 32, "step": 1,
          "default": 0
        },
        {
          "type": "header",
          "content": "t:content.padding"
        },
        {
          "type": "range",
          "id": "padding-block-start",
          "label": "t:settings.top",
          "min": 0, "max": 50, "step": 1, "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "padding-block-end",
          "label": "t:settings.bottom",
          "min": 0, "max": 50, "step": 1, "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "padding-inline-start",
          "label": "t:settings.left",
          "min": 0, "max": 50, "step": 1, "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "padding-inline-end",
          "label": "t:settings.right",
          "min": 0, "max": 50, "step": 1, "unit": "px",
          "default": 0
        }
      ]
    },
    {
      "type": "variant-title",
      "name": "t:names.product_title",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "t:content.layout"
        },
        {
          "type": "select",
          "id": "width",
          "label": "t:settings.width",
          "options": [
            { "value": "fit-content", "label": "t:options.fit" },
            { "value": "100%", "label": "t:options.fill" }
          ],
          "default": "100%"
        },
        {
          "type": "select",
          "id": "max_width",
          "label": "t:settings.max_width",
          "options": [
            { "value": "narrow", "label": "t:options.narrow" },
            { "value": "normal", "label": "t:options.normal" },
            { "value": "none", "label": "t:options.none" }
          ],
          "default": "normal"
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "t:settings.alignment",
          "options": [
            { "value": "left", "label": "t:options.left" },
            { "value": "center", "label": "t:options.center" },
            { "value": "right", "label": "t:options.right" }
          ],
          "default": "left"
        },
        {
          "type": "header",
          "content": "t:content.typography"
        },
        {
          "type": "select",
          "id": "type_preset",
          "label": "t:settings.preset",
          "options": [
            { "value": "rte", "label": "t:options.default" },
            { "value": "paragraph", "label": "t:options.paragraph" },
            { "value": "h1", "label": "t:options.h1" },
            { "value": "h2", "label": "t:options.h2" },
            { "value": "h3", "label": "t:options.h3" },
            { "value": "h4", "label": "t:options.h4" },
            { "value": "h5", "label": "t:options.h5" },
            { "value": "h6", "label": "t:options.h6" },
            { "value": "custom", "label": "t:options.custom" }
          ],
          "default": "rte",
          "info": "t:info.edit_presets_in_theme_settings"
        },
        {
          "type": "select",
          "id": "font",
          "label": "t:settings.font",
          "options": [
            { "value": "var(--font-body--family)", "label": "t:options.body" },
            { "value": "var(--font-subheading--family)", "label": "t:options.subheading" },
            { "value": "var(--font-heading--family)", "label": "t:options.heading" },
            { "value": "var(--font-accent--family)", "label": "t:options.accent" }
          ],
          "default": "var(--font-body--family)",
          "visible_if": "{{ block.settings.type_preset == 'custom' }}"
        },
        {
          "type": "select",
          "id": "font_size",
          "label": "t:settings.size",
          "options": [
            { "value": "", "label": "t:options.default" },
            { "value": "0.625rem", "label": "10px" },
            { "value": "0.75rem", "label": "12px" },
            { "value": "0.875rem", "label": "14px" },
            { "value": "1rem", "label": "16px" },
            { "value": "1.125rem", "label": "18px" },
            { "value": "1.25rem", "label": "20px" },
            { "value": "1.5rem", "label": "24px" },
            { "value": "2rem", "label": "32px" },
            { "value": "2.5rem", "label": "40px" },
            { "value": "3rem", "label": "48px" },
            { "value": "3.5rem", "label": "56px" },
            { "value": "4.5rem", "label": "72px" },
            { "value": "5.5rem", "label": "88px" },
            { "value": "7.5rem", "label": "120px" },
            { "value": "9.5rem", "label": "152px" },
            { "value": "11.5rem", "label": "184px" }
          ],
          "default": "1rem",
          "visible_if": "{{ block.settings.type_preset == 'custom' }}"
        },
        {
          "type": "select",
          "id": "line_height",
          "label": "t:settings.line_height",
          "options": [
            { "value": "tight", "label": "t:options.tight" },
            { "value": "normal", "label": "t:options.normal" },
            { "value": "loose", "label": "t:options.loose" }
          ],
          "default": "normal",
          "visible_if": "{{ block.settings.type_preset == 'custom' }}"
        },
        {
          "type": "select",
          "id": "letter_spacing",
          "label": "t:settings.letter_spacing",
          "options": [
            { "value": "tight", "label": "t:options.tight" },
            { "value": "normal", "label": "t:options.normal" },
            { "value": "loose", "label": "t:options.loose" }
          ],
          "default": "normal",
          "visible_if": "{{ block.settings.type_preset == 'custom' }}"
        },
        {
          "type": "select",
          "id": "case",
          "label": "t:settings.case",
          "options": [
            { "value": "none", "label": "t:options.default" },
            { "value": "uppercase", "label": "t:options.uppercase" }
          ],
          "default": "none",
          "visible_if": "{{ block.settings.type_preset == 'custom' }}"
        },
        {
          "type": "select",
          "id": "wrap",
          "label": "t:settings.wrap",
          "options": [
            { "value": "pretty", "label": "t:options.pretty" },
            { "value": "balance", "label": "t:options.balance" },
            { "value": "nowrap", "label": "t:options.none" }
          ],
          "visible_if": "{{ block.settings.type_preset == 'custom' }}"
        },
        {
          "type": "select",
          "id": "color",
          "label": "t:settings.color",
          "options": [
            { "value": "var(--color-foreground)", "label": "t:options.text" },
            { "value": "var(--color-foreground-heading)", "label": "t:options.heading" },
            { "value": "var(--color-primary)", "label": "t:options.link" }
          ],
          "default": "var(--color-foreground)",
          "visible_if": "{{ block.settings.type_preset != 'rte' }}"
        },
        {
          "type": "header",
          "content": "t:content.padding"
        },
        {
          "type": "range",
          "id": "padding-block-start",
          "label": "t:settings.top",
          "min": 0, "max": 50, "step": 1, "unit": "px",
          "default": 4
        },
        {
          "type": "range",
          "id": "padding-block-end",
          "label": "t:settings.bottom",
          "min": 0, "max": 50, "step": 1, "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "padding-inline-start",
          "label": "t:settings.left",
          "min": 0, "max": 50, "step": 1, "unit": "px",
          "default": 0
