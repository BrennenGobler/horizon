{% liquid
  assign product_resource = closest.product
  if request.visual_preview_mode and product_resource == blank
    assign product_resource = collections.all.products.first
  endif
-%}

{% unless product_resource == blank %}
  {% render 'variant-main-picker-custom-swatch', product_resource: product_resource %}
{% endunless %}

{% schema %}
{
  "name": "Vari Picker-Custom Swatch",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_product_variant_picker"
    },
    {
      "type": "paragraph",
      "content": "Renders color swatches from the custom_swatch metaobject (metafield: custom.custom_swatch). The metaobject must have color, name, and description fields. Falls back to theme swatches when the metafield is not set."
    },
    {
      "type": "select",
      "id": "variant_style",
      "label": "t:settings.style",
      "options": [
        {
          "value": "dropdowns",
          "label": "t:options.dropdowns"
        },
        {
          "value": "buttons",
          "label": "t:options.buttons"
        }
      ],
      "default": "buttons"
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "t:settings.swatches",
      "default": true
    },
    {
      "type": "header",
      "content": "Legend typography"
    },
    {
      "type": "select",
      "id": "legend_font",
      "label": "t:settings.font",
      "options": [
        { "value": "body", "label": "t:options.body" },
        { "value": "subheading", "label": "t:options.subheading" },
        { "value": "heading", "label": "t:options.heading" },
        { "value": "accent", "label": "t:options.accent" }
      ],
      "default": "body"
    },
    {
      "type": "select",
      "id": "legend_font_size",
      "label": "t:settings.size",
      "options": [
        { "value": "0.625rem", "label": "10px" },
        { "value": "0.75rem", "label": "12px" },
        { "value": "0.875rem", "label": "14px" },
        { "value": "1rem", "label": "16px" },
        { "value": "1.125rem", "label": "18px" }
      ],
      "default": "0.875rem"
    },
    {
      "type": "select",
      "id": "legend_text_case",
      "label": "t:settings.text_case",
      "options": [
        { "value": "none", "label": "t:options.default" },
        { "value": "uppercase", "label": "t:options.uppercase" },
        { "value": "lowercase", "label": "Lowercase" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Swatch name typography"
    },
    {
      "type": "select",
      "id": "swatch_name_font",
      "label": "t:settings.font",
      "options": [
        { "value": "body", "label": "t:options.body" },
        { "value": "subheading", "label": "t:options.subheading" },
        { "value": "heading", "label": "t:options.heading" },
        { "value": "accent", "label": "t:options.accent" }
      ],
      "default": "body"
    },
    {
      "type": "select",
      "id": "swatch_name_font_size",
      "label": "t:settings.size",
      "options": [
        { "value": "0.625rem", "label": "10px" },
        { "value": "0.75rem", "label": "12px" },
        { "value": "0.875rem", "label": "14px" },
        { "value": "1rem", "label": "16px" },
        { "value": "1.125rem", "label": "18px" }
      ],
      "default": "0.75rem"
    },
    {
      "type": "select",
      "id": "swatch_name_text_case",
      "label": "t:settings.text_case",
      "options": [
        { "value": "none", "label": "t:options.default" },
        { "value": "uppercase", "label": "t:options.uppercase" },
        { "value": "lowercase", "label": "Lowercase" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Swatch description typography"
    },
    {
      "type": "select",
      "id": "swatch_desc_font",
      "label": "t:settings.font",
      "options": [
        { "value": "body", "label": "t:options.body" },
        { "value": "subheading", "label": "t:options.subheading" },
        { "value": "heading", "label": "t:options.heading" },
        { "value": "accent", "label": "t:options.accent" }
      ],
      "default": "body"
    },
    {
      "type": "select",
      "id": "swatch_desc_font_size",
      "label": "t:settings.size",
      "options": [
        { "value": "0.625rem", "label": "10px" },
        { "value": "0.75rem", "label": "12px" },
        { "value": "0.875rem", "label": "14px" },
        { "value": "1rem", "label": "16px" },
        { "value": "1.125rem", "label": "18px" }
      ],
      "default": "0.75rem"
    },
    {
      "type": "select",
      "id": "swatch_desc_text_case",
      "label": "t:settings.text_case",
      "options": [
        { "value": "none", "label": "t:options.default" },
        { "value": "uppercase", "label": "t:options.uppercase" },
        { "value": "lowercase", "label": "Lowercase" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Custom swatch style"
    },
    {
      "type": "range",
      "id": "custom_swatch_height",
      "label": "Swatch height",
      "min": 60,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "range",
      "id": "custom_swatch_padding",
      "label": "Swatch padding",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "custom_swatch_icon_height",
      "label": "Icon height",
      "min": 10,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 50
    },
    {
      "type": "color",
      "id": "custom_swatch_active_border_color",
      "label": "Active swatch border color",
      "info": "Border color shown when a swatch is selected. Leave blank to use the default foreground color."
    },
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "t:settings.alignment",
      "default": "left"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Vari Picker-Custom Swatch",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
