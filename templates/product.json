      "settings": {
        "custom_liquid": "<style>\n/* 3-item group (size / lasts 2 months): stay on one row */\n@media screen and (max-width: 749px) {\n  .group-block--width-fit-content > .group-block-content.layout-panel-flex--row:not(.mobile-column) {\n    flex-wrap: nowrap;\n  }\n  .group-block--width-fit-content > .group-block-content.layout-panel-flex--row:not(.mobile-column) > .text-block {\n    flex: 0 0 auto;\n  }\n}\n\n/* Header group (title + price): title takes remaining space, price stays compact */\n@media screen and (max-width: 749px) {\n  .group-block--width-fill > .group-block-content.layout-panel-flex--row:not(.mobile-column) > .text-block {\n    flex: 1 1 70%;\n  }\n  .group-block--width-fill > .group-block-content.layout-panel-flex--row:not(.mobile-column) > .text-block ~ * {\n    flex: 0 0 auto;\n  }\n}\n\n.accordion--dividers accordion-custom:first-child .details {\n  border-block-start: calc(var(--style-border-width) * var(--show-fallback-borders)) solid var(--color-border);\n  border-block-start: none;\n}\n</style>",
